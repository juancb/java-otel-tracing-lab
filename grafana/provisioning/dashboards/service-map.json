{
  "annotations": {"list": []},
  "description": "Stage A: dependency graph + RED metrics. The Node Graph panel uses Tempo's service-graph metrics from Prometheus; RED panels use span-metrics. JVM panels use the metrics the OTel Java agents emit directly.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": true,
  "panels": [
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "description": "Dependency graph derived from observed traffic. Each edge is a (client_service, server_service) pair seen in spans. Hover an edge for rate / errors / p99.",
      "gridPos": {"h": 12, "w": 24, "x": 0, "y": 0},
      "id": 1,
      "options": {
        "nodes": {"mainStatUnit": "short"},
        "edges": {"mainStatUnit": "short"}
      },
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "expr": "sum by (client, server) (rate(traces_service_graph_request_total[$__rate_interval]))",
          "format": "table",
          "instant": true,
          "legendFormat": "{{client}} -> {{server}}",
          "refId": "A"
        }
      ],
      "title": "Service Graph (rate of edges over $__range)",
      "type": "nodeGraph"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "description": "Per-service request rate (calls / second).",
      "fieldConfig": {
        "defaults": {"unit": "reqps", "decimals": 2}
      },
      "gridPos": {"h": 8, "w": 8, "x": 0, "y": 12},
      "id": 2,
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "expr": "sum by (service) (rate(traces_spanmetrics_calls_total[$__rate_interval]))",
          "legendFormat": "{{service}}",
          "refId": "A"
        }
      ],
      "title": "RED — Rate by service",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "description": "Per-service error rate (calls with status_code=STATUS_CODE_ERROR).",
      "fieldConfig": {"defaults": {"unit": "reqps", "decimals": 2}},
      "gridPos": {"h": 8, "w": 8, "x": 8, "y": 12},
      "id": 3,
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "expr": "sum by (service) (rate(traces_spanmetrics_calls_total{status_code=\"STATUS_CODE_ERROR\"}[$__rate_interval]))",
          "legendFormat": "{{service}}",
          "refId": "A"
        }
      ],
      "title": "RED — Errors by service",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "description": "p99 span duration per service. Computed from span-metrics histograms.",
      "fieldConfig": {"defaults": {"unit": "s"}},
      "gridPos": {"h": 8, "w": 8, "x": 16, "y": 12},
      "id": 4,
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "expr": "histogram_quantile(0.99, sum by (le, service) (rate(traces_spanmetrics_latency_bucket[$__rate_interval])))",
          "legendFormat": "{{service}} p99",
          "refId": "A"
        }
      ],
      "title": "RED — p99 latency by service",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "description": "JVM heap used per service. Comes from the OTel Java agent, not Tempo.",
      "fieldConfig": {"defaults": {"unit": "bytes"}},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 20},
      "id": 5,
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "expr": "sum by (service_name) (jvm_memory_used_bytes{type=\"heap\"} or process_runtime_jvm_memory_usage_bytes{type=\"heap\"})",
          "legendFormat": "{{service_name}}",
          "refId": "A"
        }
      ],
      "title": "JVM heap used by service",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "description": "GC pause duration (rate). Spikes here usually correlate with RED p99 spikes.",
      "fieldConfig": {"defaults": {"unit": "s"}},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 20},
      "id": 6,
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "expr": "sum by (service_name) (rate(jvm_gc_duration_seconds_sum[$__rate_interval]) or rate(process_runtime_jvm_gc_duration_seconds_sum[$__rate_interval]))",
          "legendFormat": "{{service_name}}",
          "refId": "A"
        }
      ],
      "title": "JVM GC pause time by service",
      "type": "timeseries"
    }
  ],
  "refresh": "10s",
  "schemaVersion": 38,
  "tags": ["otel", "stage-a", "service-map", "RED"],
  "templating": {"list": []},
  "time": {"from": "now-15m", "to": "now"},
  "timepicker": {},
  "timezone": "",
  "title": "OTel Lab — service map + RED",
  "uid": "otel-lab-service-map",
  "version": 1
}
