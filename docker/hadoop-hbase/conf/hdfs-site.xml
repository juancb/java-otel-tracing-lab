<?xml version="1.0"?>
<?xml-stylesheet type="text/xsl" href="configuration.xsl"?>
<configuration>
  <!-- Single replica because we have one DataNode. -->
  <property>
    <name>dfs.replication</name>
    <value>1</value>
  </property>

  <!--
    Persist NameNode metadata and DataNode blocks under /data inside the
    container. The compose file mounts a named volume there, so HDFS state
    survives container restarts (but not `compose down -v`).
  -->
  <property>
    <name>dfs.namenode.name.dir</name>
    <value>/data/dfs/name</value>
  </property>
  <property>
    <name>dfs.datanode.data.dir</name>
    <value>/data/dfs/data</value>
  </property>

  <!-- Bind on all interfaces so the DataNode can reach the NameNode. -->
  <property>
    <name>dfs.namenode.rpc-address</name>
    <value>0.0.0.0:8020</value>
  </property>
  <property>
    <name>dfs.namenode.http-address</name>
    <value>0.0.0.0:9870</value>
  </property>

  <!--
    DataNode hostname needs to resolve from the NameNode's POV. In compose
    the service name `datanode` is the canonical hostname.
  -->
  <property>
    <name>dfs.datanode.use.datanode.hostname</name>
    <value>true</value>
  </property>
  <property>
    <name>dfs.client.use.datanode.hostname</name>
    <value>true</value>
  </property>

  <!--
    Turn off permission checking. This is a sandbox cluster; nothing about
    permissions teaches us anything about OTel.
  -->
  <property>
    <name>dfs.permissions.enabled</name>
    <value>false</value>
  </property>
</configuration>
