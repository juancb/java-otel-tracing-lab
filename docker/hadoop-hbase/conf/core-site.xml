<?xml version="1.0"?>
<?xml-stylesheet type="text/xsl" href="configuration.xsl"?>
<!--
  HDFS namenode address that all components (DataNode, HBase) point at.
  In compose, the NameNode container is reachable as `namenode`.
-->
<configuration>
  <property>
    <name>fs.defaultFS</name>
    <value>hdfs://namenode:8020</value>
  </property>

  <!--
    Allow any user to run from any host. This is a learning environment, not
    a production cluster, so we don't bother with proper auth.
  -->
  <property>
    <name>hadoop.proxyuser.root.hosts</name>
    <value>*</value>
  </property>
  <property>
    <name>hadoop.proxyuser.root.groups</name>
    <value>*</value>
  </property>
</configuration>
