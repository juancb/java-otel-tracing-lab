<?xml version="1.0"?>
<?xml-stylesheet type="text/xsl" href="configuration.xsl"?>
<configuration>
  <property>
    <name>hbase.cluster.distributed</name>
    <value>true</value>
  </property>

  <property>
    <name>hbase.rootdir</name>
    <value>hdfs://namenode:8020/hbase</value>
  </property>

  <property>
    <name>hbase.zookeeper.quorum</name>
    <value>zookeeper</value>
  </property>
  <property>
    <name>hbase.zookeeper.property.clientPort</name>
    <value>2181</value>
  </property>

  <property>
    <name>hbase.master.hostname</name>
    <value>hbase-master</value>
  </property>
  <property>
    <name>hbase.master.ipc.address</name>
    <value>0.0.0.0</value>
  </property>
  <property>
    <name>hbase.master.info.bindAddress</name>
    <value>0.0.0.0</value>
  </property>
  <property>
    <name>hbase.regionserver.hostname</name>
    <value>hbase-regionserver</value>
  </property>
  <property>
    <name>hbase.regionserver.ipc.address</name>
    <value>0.0.0.0</value>
  </property>
  <property>
    <name>hbase.regionserver.info.bindAddress</name>
    <value>0.0.0.0</value>
  </property>

  <property>
    <name>hbase.master.wait.on.regionservers.mintostart</name>
    <value>1</value>
  </property>

  <property>
    <name>zookeeper.session.timeout</name>
    <value>30000</value>
  </property>

  <property>
    <name>hbase.unsafe.stream.capability.enforce</name>
    <value>false</value>
  </property>

  <!--
    KEY FIX: HBase 2.5.x's default AsyncFSWAL provider uses reflection into
    Hadoop HDFS internals that were tested against Hadoop 3.2.x. Hadoop 3.3.x
    shifted some Netty/protobuf class structure, breaking the reflection with
    `java.lang.IllegalArgumentException: object is not an instance of declaring class`
    in ProtobufDecoder.<init> -> FanOutOneBlockAsyncDFSOutputHelper.processWriteBlockResponse.
    The master can't open its WAL, so it never finishes init, RegionServer
    never registers, deadlock.

    Switching to the synchronous `filesystem` WAL provider avoids the
    reflection path entirely. Slower per write, but works against any Hadoop.
  -->
  <property>
    <name>hbase.wal.provider</name>
    <value>filesystem</value>
  </property>
  <property>
    <name>hbase.wal.meta_provider</name>
    <value>filesystem</value>
  </property>
</configuration>
